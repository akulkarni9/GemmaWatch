OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=gemma:latest

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-32-chars!!

# Google OAuth — https://console.cloud.google.com
# Redirect URI: http://localhost:8002/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: http://localhost:8002/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated emails for role assignment
# Admins can approve HITL entries, manage settings, etc.
ADMIN_EMAILS=your@email.com
# Leave empty = any authenticated user is a viewer
ALLOWED_EMAILS=

# Base URLs
BACKEND_BASE_URL=http://localhost:8002
FRONTEND_BASE_URL=http://localhost:5173

# ── Email Alerting ────────────────────────────────────────────────────────────
# Configure via the Settings page in the dashboard after login.
# Or set these directly (optional — dashboard settings take precedence):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
